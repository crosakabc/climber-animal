#include <Windows.h>
#include <string>
#include <vector>
#include <imgui.h>
#include <ImGuiImpl.h>
#include <MelonLoader.h>
#include <Il2Cpp/Il2Cpp.h>
#include <Unity/Unity.h>
#include <Mirror/Mirror.h>

using namespace Il2Cpp;
using namespace UnityEngine;
using namespace Il2Cpp::Mirror;

// 模组配置
#define MOD_NAME "HostTeleportMod"
#define MOD_VERSION "1.0.0"
#define MOD_AUTHOR "Han"
#define TOGGLE_KEY VK_F4

// 全局变量
bool showMenu = true;
ImVec2 windowPos = ImVec2(20, 20);
ImVec2 windowSize = ImVec2(460, 430);

std::vector<GamePlayer> cachedPlayers;
GamePlayer myPlayer = nullptr;
GamePlayer selectedPlayer = nullptr;
float nextRefreshTime = 0.0f;

char inputX[64] = "0";
char inputY[64] = "20";
char inputZ[64] = "0";

// 函数声明
void RefreshPlayers();
bool TryParseCoordinates(Vector3& pos);
void TeleportLocalPlayer(Vector3 targetPos);
void TeleportRemotePlayer(GamePlayer target, Vector3 targetPos);
void DrawMainWindow();

// MelonLoader 入口函数
extern "C" __declspec(dllexport) void MelonLoader_Initialize()
{
    MelonLoader::RegisterMod(MOD_NAME, MOD_VERSION, MOD_AUTHOR);
    MelonLoader::LogInfo("[+] 传送模组已加载! 按 F4 显示/隐藏界面");
}

// 每帧更新
extern "C" __declspec(dllexport) void MelonLoader_OnUpdate()
{
    // F4 切换菜单显示
    if (GetAsyncKeyState(TOGGLE_KEY) & 1)
    {
        showMenu = !showMenu;
    }

    // 每秒刷新一次玩家列表
    if (Time::get_time() > nextRefreshTime)
    {
        RefreshPlayers();
        nextRefreshTime = Time::get_time() + 1.0f;
    }
}

// ImGui 渲染
extern "C" __declspec(dllexport) void MelonLoader_OnImGuiRender()
{
    if (!showMenu) return;
    ImGui::SetNextWindowPos(windowPos, ImGuiCond_FirstUseEver);
    ImGui::SetNextWindowSize(windowSize, ImGuiCond_FirstUseEver);
    
    ImGui::Begin("Climber Animal 传送控制台 v1.0", &showMenu, ImGuiWindowFlags_NoResize);
    DrawMainWindow();
    ImGui::End();
}

// 刷新玩家列表
void RefreshPlayers()
{
    cachedPlayers.clear();
    myPlayer = nullptr;
    selectedPlayer = nullptr;

    // 获取所有GamePlayer对象
    auto players = Object::FindObjectsOfType<GamePlayer>();
    if (!players) return;

    int count = players->Length;
    for (int i = 0; i < count; i++)
    {
        GamePlayer p = players->values[i];
        if (!p) continue;
        cachedPlayers.push_back(p);

        // 判断本地玩家
        NetworkIdentity netId = p->GetComponent<NetworkIdentity>();
        if (netId && (netId->isLocalPlayer || (!netId->isServer && !netId->isClient)))
        {
            myPlayer = p;
        }
    }

    // 单人模式兼容
    if (!myPlayer && cachedPlayers.size() == 1)
        myPlayer = cachedPlayers[0];
}

// 解析坐标输入
bool TryParseCoordinates(Vector3& pos)
{
    pos = Vector3::zero;
    try
    {
        float x = std::stof(inputX);
        float y = std::stof(inputY);
        float z = std::stof(inputZ);
        pos = Vector3(x, y, z);
        return true;
    }
    catch (...)
    {
        MelonLoader::LogError("坐标解析失败!");
        return false;
    }
}

// 传送本地玩家
void TeleportLocalPlayer(Vector3 targetPos)
{
    if (!myPlayer) return;

    // 禁用CharacterController防止传送冲突
    CharacterController cc = myPlayer->GetComponent<CharacterController>();
    if (cc) cc->enabled = false;

    myPlayer->transform->position = targetPos;

    if (cc) cc->enabled = true;
    MelonLoader::LogInfo(std::format("[本地] 已传送到: {:.1f}, {:.1f}, {:.1f}", targetPos.x, targetPos.y, targetPos.z));
}

// 传送远程玩家
void TeleportRemotePlayer(GamePlayer target, Vector3 targetPos)
{
    if (!target) return;

    NetworkTransformUnreliable netTransform = target->GetComponent<NetworkTransformUnreliable>();
    if (netTransform)
    {
        netTransform->RpcTeleport(targetPos);
        MelonLoader::LogInfo(std::format("[远程] 已传送: {}", target->gameObject->name));
    }
}

// 绘制主界面
void DrawMainWindow()
{
    ImGui::Text("▶ 房间玩家实时坐标列表");
    ImGui::Separator();

    // 玩家滚动列表
    ImGui::BeginChild("PlayersScroll", ImVec2(440, 150), true);
    for (int i = 0; i < cachedPlayers.size(); i++)
    {
        GamePlayer p = cachedPlayers[i];
        if (!p) continue;

        bool isMe = (p == myPlayer);
        Vector3 pos = p->transform->position;
        std::string playerName = p->gameObject->name;
        std::string info = std::format("{} {} | ({:.1f}, {:.1f}, {:.1f})",
            playerName, isMe ? "(我)" : "", pos.x, pos.y, pos.z);

        ImGui::Text(info.c_str());
        ImGui::SameLine();

        // 复制坐标按钮
        if (ImGui::Button(std::format("复制坐标##{}", i).c_str()))
        {
            snprintf(inputX, sizeof(inputX), "%.2f", pos.x);
            snprintf(inputY, sizeof(inputY), "%.2f", pos.y);
            snprintf(inputZ, sizeof(inputZ), "%.2f", pos.z);
        }

        // 选中按钮 (排除自己)
        if (!isMe)
        {
            ImGui::SameLine();
            if (ImGui::Button(std::format("选中##{}", i).c_str()))
            {
                selectedPlayer = p;
            }
        }
        ImGui::Spacing();
    }
    ImGui::EndChild();

    // 显示选中目标
    std::string selectedName = selectedPlayer ? selectedPlayer->gameObject->name : "未选择";
    ImGui::Text(std::format("当前选中目标: {}", selectedName).c_str());
    ImGui::Separator();

    // 双向传送按钮
    if (ImGui::Button("将 [我] 传送到 [目标]", ImVec2(215, 40)))
    {
        if (selectedPlayer && myPlayer)
            TeleportLocalPlayer(selectedPlayer->transform->position + Vector3(0, 1.5f, 0));
    }
    ImGui::SameLine();
    if (ImGui::Button("将 [目标] 传送到 [我]", ImVec2(215, 40)))
    {
        if (selectedPlayer && myPlayer)
            TeleportRemotePlayer(selectedPlayer, myPlayer->transform->position + Vector3(0, 1.5f, 0));
    }

    ImGui::Separator();
    ImGui::Text("▶ 自定义坐标");
    
    // 坐标输入框
    ImGui::Text("X:"); ImGui::SameLine(); ImGui::InputText("##X", inputX, sizeof(inputX));
    ImGui::SameLine();
    ImGui::Text("Y:"); ImGui::SameLine(); ImGui::InputText("##Y", inputY, sizeof(inputY));
    ImGui::SameLine();
    ImGui::Text("Z:"); ImGui::SameLine(); ImGui::InputText("##Z", inputZ, sizeof(inputZ));

    // 自定义坐标传送
    if (ImGui::Button("将 [我] 传送到此坐标", ImVec2(215, 40)))
    {
        Vector3 pos;
        if (TryParseCoordinates(pos)) TeleportLocalPlayer(pos);
    }
    ImGui::SameLine();
    if (ImGui::Button("将 [目标] 传送到此坐标", ImVec2(215, 40)))
    {
        if (selectedPlayer)
        {
            Vector3 pos;
            if (TryParseCoordinates(pos)) TeleportRemotePlayer(selectedPlayer, pos);
        }
    }

    ImGui::Separator();
    ImGui::Text("按 F4 隐藏界面 | 拖动顶部可移动窗口");
}